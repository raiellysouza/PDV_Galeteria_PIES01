                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <ComboBox maxWidth="1.7976931348623157E308" promptText="Não Pago" style="-fx-background-color: white; -fx-border-color: #dddddd; -fx-border-radius: 4;">
                           <items>
                              <FXCollections fx:factory="observableArrayList">
                                 <String fx:value="Não Pago" />
                                 <String fx:value="Dinheiro" />
                                 <String fx:value="PIX" />
                                 <String fx:value="Crédito" />
                                 <String fx:value="Débito" />
                              </FXCollections>
                           </items>
                        </ComboBox>
                     </children>
                  </VBox>

                  <VBox spacing="5.0">
                     <children>
                        <Label text="Valor pago">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <TextField text="0.00" style="-fx-border-color: #dddddd; -fx-background-radius: 4; -fx-border-radius: 4;" />
                     </children>
                  </VBox>

                  <VBox spacing="5.0">
                     <children>
                        <Label text="Status">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <ComboBox maxWidth="1.7976931348623157E308" promptText="Registrado" style="-fx-background-color: white; -fx-border-color: #dddddd; -fx-border-radius: 4;">
                           <items>
                              <FXCollections fx:factory="observableArrayList">
                                 <String fx:value="Registrado" />
                                 <String fx:value="Em Andamento" />
                                 <String fx:value="Pronto" />
                                 <String fx:value="Finalizado" />
                              </FXCollections>
                           </items>
                        </ComboBox>
                     </children>
                  </VBox>

                  <HBox alignment="CENTER_RIGHT" spacing="10.0">
