                                          <SVGPath content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="#ff4d4d" scaleX="0.8" scaleY="0.8" />
                                       </graphic>
                                       <cursor>
                                          <Cursor fx:constant="HAND" />
                                       </cursor>
                                    </Button>
                                 </children>
                              </HBox>
                              <Label text="Subtotal: R$ 0.00" textFill="#888888">
                                 <font>
                                    <Font size="11.0" />
                                 </font>
                                 <padding>
                                    <Insets left="5.0" />
                                 </padding>
                              </Label>
                           </children>
                        </VBox>

                        <VBox spacing="10.0" style="-fx-background-color: #f9f9f9; -fx-padding: 10; -fx-background-radius: 5;">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <TextField prefWidth="200.0" promptText="Item" style="-fx-border-color: #cccccc; -fx-background-radius: 3;" HBox.hgrow="ALWAYS" />
                                    <TextField alignment="CENTER" prefWidth="60.0" text="0" style="-fx-border-color: #cccccc; -fx-background-radius: 3;" />
                                    <TextField alignment="CENTER_RIGHT" prefWidth="100.0" text="0.00" style="-fx-border-color: #cccccc; -fx-background-radius: 3;" />
                                    
                                    <Button mnemonicParsing="false" style="-fx-background-color: transparent;">
                                       <graphic>
                                          <SVGPath content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="#ff4d4d" scaleX="0.8" scaleY="0.8" />
                                       </graphic>
                                       <cursor>
                                          <Cursor fx:constant="HAND" />
                                       </cursor>
                                    </Button>
                                 </children>
                              </HBox>
                              <Label text="Subtotal: R$ 0.00" textFill="#888888">
                                 <font>
                                    <Font size="11.0" />
                                 </font>
                                 <padding>
                                    <Insets left="5.0" />
                                 </padding>
                              </Label>
                           </children>
                        </VBox>

                        <Label alignment="CENTER_RIGHT" maxWidth="1.7976931348623157E308" text="Total: R$ 0.00">
                           <font>
                              <Font name="System Bold" size="18.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>

                  <Separator prefWidth="200.0" />

