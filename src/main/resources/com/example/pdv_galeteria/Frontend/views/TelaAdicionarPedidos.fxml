<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.TextFlow?>

<ScrollPane prefHeight="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pdv_galeteria.controller.RegistroPedidoPopupController">
    <content>
        <Pane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="1439.0" prefWidth="600.0" stylesheets="/css/BotoesTelaAdcionarPedido.css">
            <children>
                <Label layoutX="24.0" layoutY="24.0" prefHeight="37.0" prefWidth="247.0" text="Registrar Pedido">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>

                <!-- Canal da Venda -->
                <Label layoutX="24.0" layoutY="72.0" text="Canal da Venda:" />

                <CheckBox fx:id="checkLoja" layoutX="31.0" layoutY="99.0" mnemonicParsing="false" text="Loja">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </CheckBox>

                <CheckBox fx:id="checkSite" layoutX="109.0" layoutY="99.0" mnemonicParsing="false" text="Site">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </CheckBox>

                <CheckBox fx:id="checkIfood" layoutX="30.0" layoutY="131.0" mnemonicParsing="false" text="Ifood">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </CheckBox>

                <CheckBox fx:id="checkOutro" layoutX="109.0" layoutY="131.0" mnemonicParsing="false" text="Outro">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </CheckBox>

                <!-- Nome do Cliente -->
                <Label layoutX="24.0" layoutY="168.0" text="Nome do cliente*">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>

                <TextArea fx:id="campoNomeCliente" layoutX="25.0" layoutY="191.0" prefHeight="38.0" prefWidth="537.0" promptText="Nome do cliente" />

                <!-- Itens do Pedido -->
                <Label layoutX="24.0" layoutY="238.0" text="Itens do pedido*">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>

                <TreeView fx:id="treeItensPedido" layoutX="36.0" layoutY="270.0" prefHeight="49.0" prefWidth="525.0" />

                <TextFlow layoutX="41.0" layoutY="279.0" />

                <!-- Total -->
                <TextFlow layoutX="41.0" layoutY="335.0">
                    <children>
                        <Label prefHeight="17.0" prefWidth="433.0" text="Total">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label fx:id="labelTotal" prefHeight="17.0" prefWidth="71.0" text="R$00,00" />
                    </children>
                </TextFlow>

                <!-- Tipo de Entrega -->
                <Label layoutX="26.0" layoutY="384.0" text="Tipo de Entrega*">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>

                <CheckBox fx:id="checkRetirada" layoutX="39.0" layoutY="415.0" mnemonicParsing="false" text="Retirada na Loja">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </CheckBox>

                <CheckBox fx:id="checkEntrega" layoutX="184.0" layoutY="415.0" mnemonicParsing="false" text="Entrega">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </CheckBox>

                <!-- Endereço -->
                <Label layoutX="41.0" layoutY="481.0" text="Endereço*">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>

                <TextArea fx:id="campoEndereco" layoutX="43.0" layoutY="506.0" prefHeight="39.0" prefWidth="505.0" promptText="Rua, Avenida" />

                <!-- Número (parece que você tem dois campos similares, vou adicionar para ambos) -->
                <Label layoutX="40.0" layoutY="561.0" text="Número*">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>

                <TextArea fx:id="campoNumero" layoutX="39.0" layoutY="584.0" prefHeight="39.0" prefWidth="235.0" promptText="Nº" />

                <!-- Telefone -->
                <Label layoutX="293.0" layoutY="559.0" text="Telefone*">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>

                <TextArea fx:id="campoTelefone" layoutX="295.0" layoutY="584.0" prefHeight="39.0" prefWidth="235.0" promptText="(00) 00000-00000" />

                <!-- Ponto de Referência -->
                <Label layoutX="42.0" layoutY="640.0" text="Ponto de Referência*">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>

                <TextArea fx:id="campoPontoReferencia" layoutX="44.0" layoutY="665.0" prefHeight="39.0" prefWidth="505.0" promptText="EX: Perto ao mercado" />

                <!-- Observações -->
                <Label layoutX="31.0" layoutY="730.0" text="Observação sobre o pedido*">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>

                <TextArea fx:id="campoObservacoes" layoutX="33.0" layoutY="755.0" prefHeight="88.0" prefWidth="505.0" promptText="EX: Sem cebola" />

                <!-- Forma de Pagamento -->
                <Label layoutX="31.0" layoutY="868.0" text="Forma de pagamento*">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>

                <ToggleButton id="meuBotao" fx:id="btnPix" blendMode="DARKEN" layoutX="30.0" layoutY="901.0" mnemonicParsing="false" prefHeight="55.0" prefWidth="246.0" stylesheets="/css/BotoesTelaAdcionarPedido.css" text="Pix" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </ToggleButton>

                <ToggleButton id="meuBotao" fx:id="btnDinheiro" blendMode="DARKEN" layoutX="290.0" layoutY="901.0" mnemonicParsing="false" prefHeight="55.0" prefWidth="246.0" stylesheets="/css/BotoesTelaAdcionarPedido.css" text="Dinheiro" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </ToggleButton>

                <ToggleButton id="meuBotao" fx:id="btnDebito" blendMode="DARKEN" layoutX="30.0" layoutY="977.0" mnemonicParsing="false" prefHeight="55.0" prefWidth="246.0" stylesheets="/css/BotoesTelaAdcionarPedido.css" text="Débito" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </ToggleButton>

                <ToggleButton id="meuBotao" fx:id="btnCredito" blendMode="DARKEN" layoutX="290.0" layoutY="977.0" mnemonicParsing="false" prefHeight="55.0" prefWidth="246.0" stylesheets="/css/BotoesTelaAdcionarPedido.css" text="Crédito" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </ToggleButton>

                <!-- Valor Pago -->
                <Label layoutX="23.0" layoutY="1039.0" text="Valor Pago*">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>

                <TextArea fx:id="campoValorPago" layoutX="25.0" layoutY="1064.0" prefHeight="38.0" prefWidth="537.0" promptText="R$00,00" />

                <!-- Troco -->
                <TextArea fx:id="campoTroco" disable="true" layoutX="25.0" layoutY="1113.0" prefHeight="38.0" prefWidth="537.0" promptText="Troco : R$ 00,00">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </TextArea>

                <!-- Botão Registrar -->
                <Button fx:id="btnRegistrarPedido" layoutX="175.0" layoutY="1200.0" mnemonicParsing="false" onAction="#handleRegistrarVenda" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: #28a745; -fx-background-radius: 8px;" text="Registrar Pedido" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>

                <!-- Tempo de Previsão -->
                <Label layoutX="19.0" layoutY="1159.0" text="Tempo de Previsão de Preparo">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>
            </children>
        </Pane>
    </content>
</ScrollPane>
