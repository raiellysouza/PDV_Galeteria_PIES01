<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="227.0" prefWidth="500.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label layoutX="22.0" layoutY="10.0" text="Fechamento de Caixa">
         <font>
            <Font name="System Bold" size="26.0" />
         </font>
      </Label>

      <Label layoutX="470.0" layoutY="14.0" style="-fx-cursor: hand;" text="x" textFill="#171717">
         <font>
            <Font size="20.0" />
         </font>
      </Label>

      <Label layoutX="22.0" layoutY="44.0" text="Informe o valor final em dinheiro no caixa" textFill="#2f3542">
         <font>
            <Font size="14.0" />
         </font>
      </Label>

      <Label layoutX="32.0" layoutY="75.0" text="Valor final (R$)">
         <font>
            <Font size="14.0" />
         </font>
      </Label>

      <TextField fx:id="txtValorInicial" layoutX="32.0" layoutY="104.0" prefHeight="40.0" prefWidth="436.0" style="-fx-background-color: white; -fx-border-color: #ced6e0; -fx-border-radius: 5; -fx-background-radius: 5;" text="0,00">
         <font>
            <Font size="16.0" />
         </font>
      </TextField>

      <Button fx:id="btnConfirmar" layoutX="32.0" layoutY="159.0" mnemonicParsing="false" prefHeight="45.0" prefWidth="436.0" style="-fx-background-color: #f0932b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Confirmar Fechamento">
         <font>
            <Font size="16.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
