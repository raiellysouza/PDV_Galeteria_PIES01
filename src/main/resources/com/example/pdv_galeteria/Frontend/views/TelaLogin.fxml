                                    </font>
                                </Label>
                                <TextField fx:id="campoUsuario" prefHeight="45.0" promptText="Digite seu usuário" style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5;" styleClass="text-field">
                                    <font>
                                        <Font size="16.0" />
                                    </font>
                                </TextField>
                            </children>
                            <VBox.margin>
                                <Insets bottom="20.0" />
                            </VBox.margin>
                        </VBox>

                        <VBox alignment="CENTER_LEFT" spacing="5.0">
                            <children>
                                <Label text="Senha" textFill="BLACK">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <PasswordField fx:id="campoSenha" prefHeight="45.0" promptText="Digite sua senha" style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5;" styleClass="text-field">
                                    <font>
                                        <Font size="16.0" />
                                    </font>
                                </PasswordField>
                                
                                <Label alignment="CENTER_RIGHT" maxWidth="1.7976931348623157E308" text="Esqueci minha senha" textFill="#666666">
                                    <font>
                                        <Font size="12.0" />
                                    </font>
                                    <cursor>
                                        <Cursor fx:constant="HAND" />
