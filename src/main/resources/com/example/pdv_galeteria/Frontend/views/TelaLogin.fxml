                <VBox alignment="CENTER" maxWidth="450.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                    </padding>
                    <children>
                        
                        <Label text="Login" textFill="BLACK">
                            <font>
                                <Font name="System Bold" size="32.0" />
